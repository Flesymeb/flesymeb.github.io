&lt;script>
(() => {
const root = document.getElementById("typewriter-0");
if (!root) return;
const output = root.querySelector(".typewriter-output");
const cursor = root.querySelector(".cmd-cursor");
const lines = [...root.querySelectorAll(".typewriter-source .line")]
.map((element) => element.textContent)
.filter((line) => line &amp;&amp; line.trim().length > 0);
const prompt = "hyoung@flesymeb:~$ ";
const speed = Number("26") || 30;
const lineDelay = Number("520") || 500;
let lineIndex = 0;
let charIndex = 0;
let currentLine = "";
let currentMode = "plain";
let currentTextNode = null;
let currentLineNode = null;
let currentPrepared = null;
function createLine(mode) {
const line = document.createElement("span");
line.className = "tw-line";
if (mode === "command") {
const promptNode = document.createElement("span");
promptNode.className = "tw-prompt";
promptNode.textContent = prompt;
const commandNode = document.createElement("span");
commandNode.className = "tw-command";
line.appendChild(promptNode);
line.appendChild(commandNode);
output.appendChild(line);
currentLineNode = line;
return commandNode;
}
const modeNode = document.createElement("span");
if (mode === "output-pop") {
modeNode.className = "tw-output-pop";
} else if (mode === "progress") {
modeNode.className = "tw-progress";
} else if (mode === "success") {
modeNode.className = "tw-success";
} else {
modeNode.className = mode === "output" ? "tw-output" : "tw-plain";
}
line.appendChild(modeNode);
output.appendChild(line);
currentLineNode = line;
return modeNode;
}
function prepareLine(rawLine) {
if (rawLine.startsWith("$ ")) {
return { mode: "command", text: rawLine.slice(2) };
}
if (rawLine.startsWith("!bar ")) {
return { mode: "progress", text: rawLine.slice(5) || "loading" };
}
if (rawLine.startsWith("!ok ")) {
return { mode: "success", text: rawLine.slice(4) };
}
if (rawLine.startsWith("!pop ")) {
return { mode: "output-pop", text: rawLine.slice(5) };
}
if (rawLine.startsWith("! ")) {
return { mode: "output", text: rawLine.slice(2) };
}
return { mode: "plain", text: rawLine };
}
function animateProgress(label, done) {
currentTextNode = createLine("progress");
if (currentLineNode) {
currentLineNode.appendChild(cursor);
}
let percent = 0;
const totalBlocks = 24;
function render() {
const filled = Math.round((percent / 100) * totalBlocks);
const bar = "■".repeat(filled) + "□".repeat(totalBlocks - filled);
currentTextNode.textContent = `${label} [${bar}] ${percent}%`;
}
render();
const timer = setInterval(() => {
const step = percent &lt; 70 ? 7 : percent &lt; 90 ? 4 : 2;
percent = Math.min(100, percent + step);
render();
cursor.classList.add("hit");
setTimeout(() => cursor.classList.remove("hit"), 70);
if (percent >= 100) {
clearInterval(timer);
done();
}
}, 85);
}
function typeNextChar() {
if (lineIndex >= lines.length) return;
if (charIndex === 0) {
const prepared = prepareLine(lines[lineIndex]);
currentPrepared = prepared;
currentMode = prepared.mode;
currentLine = prepared.text;
if (currentMode === "progress") {
animateProgress(currentLine, () => {
lineIndex += 1;
charIndex = 0;
setTimeout(typeNextChar, lineDelay);
});
return;
}
currentTextNode = createLine(currentMode);
if (currentLineNode) {
currentLineNode.appendChild(cursor);
}
}
if (charIndex &lt; currentLine.length) {
currentTextNode.textContent += currentLine.charAt(charIndex);
cursor.classList.add("hit");
setTimeout(() => cursor.classList.remove("hit"), Math.max(60, speed));
charIndex += 1;
setTimeout(typeNextChar, speed);
return;
}
lineIndex += 1;
charIndex = 0;
setTimeout(typeNextChar, lineDelay);
}
typeNextChar();
})();
&lt;/script>
